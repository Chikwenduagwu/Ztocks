# Stellar network
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Contract IDs — fill these in after deploying (see
# ztocks-contracts/contracts/README.md), then run
# scripts/generate-bindings.sh to generate typed client packages.
NEXT_PUBLIC_ORACLE_CONTRACT_ID=
NEXT_PUBLIC_VAULT_CONTRACT_ID=
NEXT_PUBLIC_LENDING_CONTRACT_ID=
NEXT_PUBLIC_ZK_VERIFIER_CONTRACT_ID=
NEXT_PUBLIC_USDC_CONTRACT_ID=

# Optional: URL of a small backend endpoint wrapping
# `cargo run --bin encode_proof` (see ztocks-contracts/contracts/
# zk-verifier/src/bin/encode_proof.rs and hooks/useZkProof.ts's
# module doc comment for why this exists). Without this set, proof
# submission on the Portfolio page will show a clear setup error
# instead of silently using an unverified encoding.
NEXT_PUBLIC_PROOF_ENCODER_URL=
