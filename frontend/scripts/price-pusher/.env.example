# --- Stock data provider ---
# "finnhub" or "twelvedata"
STOCK_API_PROVIDER=finnhub
STOCK_API_KEY=your_api_key_here

# --- Stellar network ---
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# --- Deployed contract + pusher identity ---
# Contract ID returned by `stellar contract deploy` for price-oracle
ORACLE_CONTRACT_ID=

# Secret key (starts with "S...") of the Stellar account registered
# as the oracle's `pusher` address during `initialize`. Keep this
# separate from your admin key — see contracts/README.md.
PUSHER_SECRET_KEY=

# How often to push fresh prices, in seconds.
PUSH_INTERVAL_SECONDS=60

# Mapping of on-chain symbol -> API ticker, comma-separated.
ASSETS=AAPLX:AAPL,TSLAX:TSLA,NVDAX:NVDA,GOOGLX:GOOGL
